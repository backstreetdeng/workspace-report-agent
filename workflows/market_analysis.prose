# 汽车市场战略决策智能体
# OpenProse 标准语法 + Skills 集成版

# ======================
# 1. 定义专业分析智能体
# ======================
# 注意：Skills 需要先通过 openclaw skills install 安装，或放在 workspace/skills/ 目录

agent market_analyst:
  model: sonnet
  prompt: """
    你是15年经验的专业汽车市场战略分析师。

    可用的 Skills（通过 skills 属性启用）：
    - intent-classifier: 意图分类
    - pg-vector-search: 向量知识库检索
    - nl2sql-pg: 结构化数据库查询
    - automotive-strategy-analysis: 战略分析(PEST/波特五力/SWOT/4P)
    - report-generator: 报告生成

    当需要执行特定任务时，使用对应的 skill 工具。
  """
  skills: ["intent-classifier", "pg-vector-search", "nl2sql-pg", "automotive-strategy-analysis", "report-generator"]

# ======================
# 2. 输入定义
# ======================
input question: "用户的市场分析问题"

# ======================
# 3. 阶段1：意图识别
# ======================
let intent_result = session: market_analyst
  prompt: |
    请使用 intent-classifier 工具识别用户问题的意图类型。

    用户问题：{question}

    执行意图分类，获取：
    - intent_type: 意图类型（趋势分析/竞品分析/机会识别等）
    - confidence: 置信度
    - brands_mentioned: 提到的品牌
    - dimensions: 分析维度

# ======================
# 4. 阶段2：数据检索
# ======================
let vector_data = session: market_analyst
  prompt: |
    请使用 pg-vector-search 工具检索向量知识库。

    用户问题：{question}

    执行向量检索，获取相关市场数据、行业报告、政策文件等。

let sql_data = session: market_analyst
  prompt: |
    请使用 nl2sql-pg 工具执行结构化数据查询。

    用户问题：{question}

    执行SQL查询，获取销量数据、市场份额、趋势数据等结构化信息。

# ======================
# 5. 阶段3：战略分析
# ======================
let pest_data = session: market_analyst
  prompt: |
    请使用 automotive-strategy-analysis 工具执行PEST宏观环境分析。

    分析汽车行业的：
    - Political（政治）：新能源政策、补贴、双积分
    - Economic（经济）：消费、价格战、成本
    - Social（社会）：环保、充电基础设施、用户偏好
    - Technological（技术）：电池、智能驾驶、平台化

let porter_data = session: market_analyst
  prompt: |
    请使用 automotive-strategy-analysis 工具执行波特五力竞争分析。

    分析：
    - 现有竞争者
    - 潜在进入者
    - 替代品威胁
    - 供应商议价
    - 购买者议价

# 品牌分析（条件执行）
if intent_result.brands_mentioned:
  let brand = intent_result.brands_mentioned.[0]

  let swot_data = session: market_analyst
    prompt: |
      请使用 automotive-strategy-analysis 工具执行SWOT战略分析。

      品牌：{brand}

      分析优势、劣势、机会、威胁。

  let fourp_data = session: market_analyst
    prompt: |
      请使用 automotive-strategy-analysis 工具执行4P营销分析。

      品牌：{brand}

      分析产品、价格、渠道、促销策略。
else:
  let swot_data = null
  let fourp_data = null

# ======================
# 6. 阶段4：报告生成
# ======================
output analysis_report = session: market_analyst
  prompt: |
    请使用 report-generator 工具生成完整的市场战略分析报告。

    用户问题：{question}
    意图类型：{intent_result.intent_type}
    向量数据：{vector_data}
    SQL数据：{sql_data}
    PEST分析：{pest_data}
    波特五力：{porter_data}
    SWOT分析：{swot_data}
    4P分析：{fourp_data}

    生成包含以下部分的Markdown报告：
    1. 执行摘要
    2. 市场现状与数据
    3. PEST宏观分析
    4. 竞争格局（波特五力）
    5. SWOT战略研判
    6. 4P营销分析
    7. 市场机会与风险
    8. 战略建议
