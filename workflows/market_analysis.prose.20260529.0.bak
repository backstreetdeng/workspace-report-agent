prose
# 汽车市场战略决策智能体 - 最终上线版 Prose 工作流
# 适配：PostgreSQL结构化 + PgVector向量知识库
# 集成：PEST/波特五力/SWOT/4P 四大框架 + 三大工具

## start
# 接收用户原始问题
set user_question = {{user.input}}
print "🚗 汽车市场战略智能体启动，正在执行全链路专业分析..."

# ======================================
# 1. 智能数据收集（双库动态查询）
# ======================================
# 1.1 结构化数据查询 PostgreSQL（NL2SQL动态生成，无写死SQL）
call_skill nl2sql_pg
args:
  question: {{user_question}}
  db_schema: auto
  db_type: postgresql
set dynamic_sql = {{nl2sql_pg.sql}}

call_skill pg_structured_query
args:
  sql: {{dynamic_sql}}
set structured_data = {{pg_structured_query.result}}

# 1.2 非结构化语义查询 PgVector
call_skill pg_vector_search
args:
  query: {{user_question}}
  top_k: 6
  vector_table: industry_knowledge_embedding
set vector_knowledge = {{pg_vector_search.result}}

# 1.3 数据清洗与规整
call_skill data_cleaner
args:
  structured_data: {{structured_data}}
  vector_data: {{vector_knowledge}}
set standard_data = {{data_cleaner.result}}

# ======================================
# 2. 竞品专项分析（调用专属工具）
# ======================================
call_skill competitor_analysis_tool
args:
  origin_question: {{user_question}}
  base_data: {{standard_data}}
set competitor_result = {{competitor_analysis_tool.result}}

# ======================================
# 3. 四大专业分析框架固化推演
# ======================================

# 3.1 PEST宏观分析
call_analyzer pest_analysis
args:
  full_data: {{standard_data}}
  rule: 严格按照PEST政策/经济/社会/技术四维度输出
set pest_result = {{pest_analysis.result}}

# 3.2 波特五力竞争格局分析
call_analyzer porter_analysis
args:
  full_data: {{standard_data}}
  rule: 严格按照五力模型解析行业竞争烈度与壁垒
set porter_result = {{porter_analysis.result}}

# 3.3 SWOT战略定位分析
call_analyzer swot_analysis
args:
  data: {{standard_data}}
  competitor_data: {{competitor_result}}
  rule: 输出明确的优势、劣势、机会、威胁，禁止空泛描述
set swot_result = {{swot_analysis.result}}

# 3.4 4P营销组合分析
call_analyzer fourp_analysis
args:
  market_data: {{standard_data}}
  rule: 从产品、价格、渠道、推广四个维度拆解市场打法
set fourp_result = {{fourp_analysis.result}}

# ======================================
# 4. 趋势研判 + 机会识别
# ======================================
call_strategy trend_judge
args:
  pest: {{pest_result}}
  porter: {{porter_result}}
  swot: {{swot_result}}
  fourp: {{fourp_result}}
set trend_conclusion = {{trend_judge.result}}

call_strategy opportunity_scan
args:
  trend_data: {{trend_conclusion}}
  market_data: {{standard_data}}
set opportunity_result = {{opportunity_scan.result}}

# ======================================
# 5. 输出战略建议
# ======================================
call_strategy strategy_suggest
args:
  trend: {{trend_conclusion}}
  opportunity: {{opportunity_result}}
  swot: {{swot_result}}
set final_strategy = {{strategy_suggest.result}}

# ======================================
# 6. 生成标准化咨询报告
# ======================================
call_skill report_generator
args:
  question: {{user_question}}
  data_base: {{standard_data}}
  competitor: {{competitor_result}}
  pest: {{pest_result}}
  porter: {{porter_result}}
  swot: {{swot_result}}
  fourp: {{fourp_result}}
  trend: {{trend_conclusion}}
  opportunity: {{opportunity_result}}
  strategy: {{final_strategy}}
set final_report = {{report_generator.result}}

# ======================================
# 7. 最终输出 + 记忆归档
# ======================================
print "\n========== 汽车市场战略分析正式报告 ==========\n"
print {{final_report}}

save_memory
content:
  用户问题：{{user_question}}
  分析报告：{{final_report}}
end